{
  "name": "pantone-theme",
  "displayName": "Pantone Theme",
  "description": "A collection of VS Code color themes based on official Pantone colors, featuring analogous and complementary color harmonies with bold/italic syntax styling.",
  "version": "0.1.0",
  "publisher": "AndlzEngineering",
  "license": "MIT",
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.60.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "color-theme",
    "pantone",
    "dark-theme",
    "light-theme",
    "peacock"
  ],
  "galleryBanner": {
    "color": "#a47864",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/and-lz/pantone-vscode-themes"
  },
  "homepage": "https://github.com/and-lz/pantone-vscode-themes#readme",
  "bugs": {
    "url": "https://github.com/and-lz/pantone-vscode-themes/issues"
  },
  "scripts": {
    "build": "node src/build.js",
    "package": "vsce package"
  },
  "contributes": {
    "commands": [
      {
        "command": "pantoneTheme.matchPeacock",
        "title": "Pantone Theme: Match Peacock Color"
      }
    ],
