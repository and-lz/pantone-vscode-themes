{
  "name": "Pantone Pewter (Light)",
  "type": "light",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable.declaration": {
      "foreground": "#171818"
    },
    "variable.readonly": {
      "foreground": "#38793a",
      "bold": true
    },
    "parameter.declaration": {
      "foreground": "#171818",
      "italic": true
    },
    "function.declaration": {
      "foreground": "#716962",
      "bold": true
    },
    "function.defaultLibrary": {
      "foreground": "#716962"
    },
    "type": {
      "foreground": "#007986",
      "italic": true
    },
    "type.defaultLibrary": {
      "foreground": "#007986",
      "italic": true
    },
    "class": {
      "foreground": "#5a7431",
      "bold": true,
      "italic": true
    },
    "interface": {
      "foreground": "#007986",
      "italic": true
    },
    "enum": {
      "foreground": "#007986",
      "italic": true
    },
    "enumMember": {
      "foreground": "#38793a",
      "bold": true
    },
    "namespace": {
      "foreground": "#007986"
    },
    "property.readonly": {
      "foreground": "#38793a",
      "bold": true
    }
  },
  "colors": {
