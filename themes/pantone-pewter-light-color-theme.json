    "terminalCursor.foreground": "#7b7e7e",
    "terminal.ansiBlack": "#171818",
    "terminal.ansiRed": "#bf1932",
    "terminal.ansiGreen": "#4e9a2f",
    "terminal.ansiYellow": "#d4a017",
