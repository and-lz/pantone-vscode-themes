    "editor.lineHighlightBackground": "#9e4fa51a",
    "editor.lineHighlightBorder": "#9e4fa500",
    "editor.findMatchBackground": "#f5a26f66",
    "editor.findMatchHighlightBackground": "#f5a26f33",
    "editor.wordHighlightBackground": "#9e4fa533",
    "editorBracketMatch.background": "#9e4fa540",
    "editorBracketMatch.border": "#9e4fa599",
    "editorIndentGuide.background": "#9a9e9d33",
    "editorIndentGuide.activeBackground": "#9a9e9d73",
    "editorWhitespace.foreground": "#9a9e9d33",
    "editorRuler.foreground": "#9a9e9d26",
    "editorLineNumber.foreground": "#9a9e9d",
    "editorLineNumber.activeForeground": "#f4f5f0",
    "editorGutter.addedBackground": "#88b04b",
    "editorGutter.modifiedBackground": "#efc050",
    "editorGutter.deletedBackground": "#dd4132",
    "editorError.foreground": "#dd4132",
    "editorWarning.foreground": "#efc050",
    "editorInfo.foreground": "#97d700",
    "sideBar.background": "#29152b",
    "sideBar.foreground": "#f0e9ee",
    "sideBar.border": "#361b38",
    "sideBarTitle.foreground": "#f0e9ee",
    "sideBarSectionHeader.background": "#9e4fa526",
