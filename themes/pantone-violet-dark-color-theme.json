{
  "name": "Pantone Violet (Dark)",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable.declaration": {
      "foreground": "#f4f5f0"
    },
    "variable.readonly": {
      "foreground": "#f7a08b",
      "bold": true
    },
    "parameter.declaration": {
      "foreground": "#f4f5f0",
      "italic": true
    },
    "function.declaration": {
      "foreground": "#d4a017",
      "bold": true
    },
    "function.defaultLibrary": {
      "foreground": "#d4a017"
    },
    "type": {
      "foreground": "#2c9fd9",
      "italic": true
    },
    "type.defaultLibrary": {
      "foreground": "#2c9fd9",
      "italic": true
    },
    "class": {
      "foreground": "#006e7f",
      "bold": true,
      "italic": true
    },
    "interface": {
      "foreground": "#2c9fd9",
      "italic": true
    },
    "enum": {
      "foreground": "#2c9fd9",
      "italic": true
    },
    "enumMember": {
      "foreground": "#f7a08b",
      "bold": true
    },
    "namespace": {
      "foreground": "#2c9fd9"
    },
    "property.readonly": {
      "foreground": "#f7a08b",
      "bold": true
    }
  },
  "colors": {
    "editor.background": "#190d1a",
    "editor.foreground": "#f0e9ee",
    "editorCursor.foreground": "#9e4fa5",
    "editor.selectionBackground": "#9e4fa54d",
