    "statusBar.border": "#361b38",
    "statusBar.debuggingBackground": "#97d700",
    "statusBar.debuggingForeground": "#f4f5f0",
    "statusBar.noFolderBackground": "#211123",
    "statusBarItem.hoverBackground": "#f4f5f033",
    "statusBarItem.remoteBackground": "#9e4fa5",
    "statusBarItem.remoteForeground": "#f4f5f0",
    "input.background": "#211123",
    "input.foreground": "#f0e9ee",
    "input.border": "#361b38",
    "input.placeholderForeground": "#b9a384",
    "inputOption.activeBorder": "#9e4fa5",
    "inputValidation.errorBorder": "#dd4132",
    "inputValidation.warningBorder": "#efc050",
    "inputValidation.infoBorder": "#97d700",
    "dropdown.background": "#211123",
    "dropdown.foreground": "#f0e9ee",
    "dropdown.border": "#361b38",
    "list.activeSelectionBackground": "#9e4fa54d",
    "list.activeSelectionForeground": "#f0e9ee",
    "list.hoverBackground": "#9e4fa526",
    "list.inactiveSelectionBackground": "#9e4fa526",
    "list.focusBackground": "#9e4fa533",
    "list.highlightForeground": "#9e4fa5",
    "button.background": "#9e4fa5",
    "button.foreground": "#f4f5f0",
    "button.hoverBackground": "#9e4fa5d9",
    "button.secondaryBackground": "#29152b",
    "button.secondaryForeground": "#f0e9ee",
    "badge.background": "#9e4fa5",
    "badge.foreground": "#f4f5f0",
    "scrollbar.shadow": "#21232245",
    "scrollbarSlider.background": "#9a9e9d40",
    "scrollbarSlider.hoverBackground": "#9a9e9d66",
    "scrollbarSlider.activeBackground": "#9a9e9d8c",
    "minimap.background": "#190d1a",
    "minimap.findMatchHighlight": "#f5a26f99",
    "minimap.selectionHighlight": "#9e4fa566",
    "panel.background": "#211123",
    "panel.border": "#361b38",
    "panelTitle.activeBorder": "#9e4fa5",
    "panelTitle.activeForeground": "#f0e9ee",
    "panelTitle.inactiveForeground": "#b9a384",
    "terminal.background": "#211123",
    "terminal.foreground": "#f0e9ee",
    "terminalCursor.foreground": "#9e4fa5",
    "terminal.ansiBlack": "#190d1a",
    "terminal.ansiRed": "#dd4132",
    "terminal.ansiGreen": "#88b04b",
    "terminal.ansiYellow": "#efc050",
    "terminal.ansiBlue": "#0f4c81",
    "terminal.ansiMagenta": "#b163a3",
    "terminal.ansiCyan": "#45b5aa",
    "terminal.ansiWhite": "#f4f5f0",
    "terminal.ansiBrightBlack": "#b9a384",
    "terminal.ansiBrightRed": "#f9423a",
    "terminal.ansiBrightGreen": "#88b04b",
    "terminal.ansiBrightYellow": "#efc050",
    "terminal.ansiBrightBlue": "#2c9fd9",
    "terminal.ansiBrightMagenta": "#c74375",
    "terminal.ansiBrightCyan": "#7bc4e2",
    "terminal.ansiBrightWhite": "#f4f5f0",
    "gitDecoration.addedResourceForeground": "#88b04b",
    "gitDecoration.modifiedResourceForeground": "#efc050",
    "gitDecoration.deletedResourceForeground": "#dd4132",
    "gitDecoration.untrackedResourceForeground": "#88b04b",
    "gitDecoration.conflictingResourceForeground": "#ff6f61",
    "gitDecoration.ignoredResourceForeground": "#b9a384",
    "breadcrumb.foreground": "#b9a384",
    "breadcrumb.focusForeground": "#f4f5f0",
    "breadcrumb.activeSelectionForeground": "#f4f5f0",
    "notifications.background": "#29152b",
    "notifications.foreground": "#f0e9ee",
    "notificationLink.foreground": "#9e4fa5",
    "peekView.border": "#9e4fa5",
    "peekViewEditor.background": "#211123",
    "peekViewResult.background": "#29152b",
    "peekViewTitle.background": "#211123",
    "editorWidget.background": "#211123",
    "editorWidget.border": "#361b38",
    "editorSuggestWidget.selectedBackground": "#9e4fa540",
    "focusBorder": "#9e4fa599",
    "selection.background": "#9e4fa54d",
    "textLink.foreground": "#97d700",
    "textLink.activeForeground": "#97d700",
    "progressBar.background": "#9e4fa5",
    "icon.foreground": "#b9a384",
    "descriptionForeground": "#b9a384"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "comment.block.documentation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#b9a384",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#9e4fa5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword operators",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.instanceof",
        "keyword.operator.typeof",
        "keyword.operator.logical",
        "keyword.operator.delete"
      ],
      "settings": {
        "foreground": "#9e4fa5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage type (class, function, var, let, const)",
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#9e4fa5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.template",
        "string.quoted.other"
      ],
      "settings": {
        "foreground": "#97d700",
        "fontStyle": ""
      }
    },
    {
      "name": "String interpolation",
      "scope": [
        "string.interpolated",
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#9e4fa5",
        "fontStyle": ""
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#97d700",
        "fontStyle": ""
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex"
      ],
      "settings": {
        "foreground": "#f5a26f",
        "fontStyle": ""
      }
    },
    {
      "name": "Language constants (true, false, null)",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#f7a08b",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Other constants (ALL_CAPS, enums)",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#f7a08b",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Escape characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#decdbe",
        "fontStyle": ""
      }
    },
    {
      "name": "Type names and interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.alias",
        "entity.name.type.module",
        "support.type",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#2c9fd9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Type parameters (generics <T>)",
      "scope": [
        "entity.name.type.parameter"
      ],
      "settings": {
        "foreground": "#2c9fd9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function declarations",
      "scope": [
        "entity.name.function",
        "meta.function entity.name.function"
      ],
      "settings": {
        "foreground": "#d4a017",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Function calls",
      "scope": [
        "meta.function-call entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#d4a017",
        "fontStyle": ""
      }
    },
    {
      "name": "Method calls",
      "scope": [
        "meta.method-call entity.name.function",
        "entity.name.function.member"
      ],
      "settings": {
        "foreground": "#d4a017",
        "fontStyle": ""
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#f4f5f0",
        "fontStyle": ""
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#f4f5f0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Language variables (this, self, super)",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#9e4fa5",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#f4f5f0",
        "fontStyle": ""
      }
    },
    {
      "name": "Class names",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#006e7f",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Inherited classes",
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#006e7f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "HTML/XML tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#9e4fa5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "HTML/XML attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#d4a017",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#decdbe",
        "fontStyle": ""
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#9a9e9d",
        "fontStyle": ""
      }
    },
    {
      "name": "Decorators / Annotations",
      "scope": [
        "meta.decorator",
        "meta.decorator entity.name.function",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#2c9fd9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.vendored.property-name.css"
      ],
      "settings": {
        "foreground": "#2c9fd9",
        "fontStyle": ""
      }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#006e7f",
        "fontStyle": "bold"
      }
    },
    {
      "name": "CSS values",
      "scope": [
        "support.constant.property-value.css",
        "support.constant.color.css"
      ],
      "settings": {
        "foreground": "#f7a08b",
        "fontStyle": ""
      }
    },
    {
      "name": "CSS units",
      "scope": [
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#f5a26f",
        "fontStyle": ""
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#2c9fd9",
        "fontStyle": ""
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "markup.heading entity.name",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#9e4fa5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#f7a08b",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#2c9fd9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown inline code",
      "scope": [
        "markup.inline.raw",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#97d700",
        "fontStyle": ""
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#d4a017",
        "fontStyle": ""
      }
    },
    {
      "name": "Markdown quotes",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#b9a384",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#88b04b"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#dd4132"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#efc050"
      }
    }
  ]
}