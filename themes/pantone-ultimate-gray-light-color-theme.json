    "statusBar.border": "#cecfd0",
    "statusBar.debuggingBackground": "#e69945",
    "statusBar.debuggingForeground": "#f6f7f7",
    "statusBar.noFolderBackground": "#ececec",
    "statusBarItem.hoverBackground": "#f6f7f733",
    "statusBarItem.remoteBackground": "#646567",
    "statusBarItem.remoteForeground": "#161617",
    "input.background": "#f9f9f9",
    "input.foreground": "#161617",
    "input.border": "#cecfd0",
    "input.placeholderForeground": "#939597",
    "inputOption.activeBorder": "#767779",
    "inputValidation.errorBorder": "#bf1932",
    "inputValidation.warningBorder": "#d4a017",
    "inputValidation.infoBorder": "#e69945",
    "dropdown.background": "#f9f9f9",
    "dropdown.foreground": "#161617",
    "dropdown.border": "#cecfd0",
    "list.activeSelectionBackground": "#76777933",
    "list.activeSelectionForeground": "#161617",
    "list.hoverBackground": "#7677791a",
    "list.inactiveSelectionBackground": "#7677791a",
    "list.focusBackground": "#76777926",
    "list.highlightForeground": "#767779",
    "button.background": "#767779",
    "button.foreground": "#161617",
    "button.hoverBackground": "#6a6b6d",
    "button.secondaryBackground": "#ececec",
    "button.secondaryForeground": "#161617",
    "badge.background": "#767779",
    "badge.foreground": "#161617",
    "scrollbar.shadow": "#0f0f0f14",
    "scrollbarSlider.background": "#1616171a",
    "scrollbarSlider.hoverBackground": "#16161733",
    "scrollbarSlider.activeBackground": "#1616174d",
    "minimap.background": "#f9f9f9",
    "minimap.findMatchHighlight": "#76ff7b80",
    "minimap.selectionHighlight": "#7677794d",
    "panel.background": "#f2f2f3",
    "panel.border": "#cecfd0",
    "panelTitle.activeBorder": "#767779",
    "panelTitle.activeForeground": "#161617",
    "panelTitle.inactiveForeground": "#939597",
    "terminal.background": "#f2f2f3",
    "terminal.foreground": "#161617",
    "terminalCursor.foreground": "#767779",
    "terminal.ansiBlack": "#161617",
    "terminal.ansiRed": "#bf1932",
    "terminal.ansiGreen": "#4e9a2f",
    "terminal.ansiYellow": "#d4a017",
    "terminal.ansiBlue": "#0f4c81",
    "terminal.ansiMagenta": "#8c3359",
    "terminal.ansiCyan": "#006e7f",
    "terminal.ansiWhite": "#f9f9f9",
    "terminal.ansiBrightBlack": "#939597",
    "terminal.ansiBrightRed": "#dd4132",
    "terminal.ansiBrightGreen": "#88b04b",
    "terminal.ansiBrightYellow": "#efc050",
    "terminal.ansiBrightBlue": "#2c9fd9",
    "terminal.ansiBrightMagenta": "#b163a3",
    "terminal.ansiBrightCyan": "#45b5aa",
    "terminal.ansiBrightWhite": "#f6f7f7",
    "gitDecoration.addedResourceForeground": "#4e9a2f",
    "gitDecoration.modifiedResourceForeground": "#d4a017",
    "gitDecoration.deletedResourceForeground": "#bf1932",
    "gitDecoration.untrackedResourceForeground": "#4e9a2f",
    "gitDecoration.conflictingResourceForeground": "#dd4132",
    "gitDecoration.ignoredResourceForeground": "#939597",
    "breadcrumb.foreground": "#939597",
    "breadcrumb.focusForeground": "#161617",
    "breadcrumb.activeSelectionForeground": "#161617",
    "notifications.background": "#f9f9f9",
    "notifications.foreground": "#161617",
    "notificationLink.foreground": "#767779",
    "peekView.border": "#767779",
    "peekViewEditor.background": "#f2f2f3",
    "peekViewResult.background": "#ececec",
    "peekViewTitle.background": "#f2f2f3",
    "editorWidget.background": "#f9f9f9",
    "editorWidget.border": "#cecfd0",
    "editorSuggestWidget.selectedBackground": "#76777926",
    "focusBorder": "#76777980",
    "selection.background": "#76777933",
    "textLink.foreground": "#e69945",
    "textLink.activeForeground": "#cc883e",
    "progressBar.background": "#767779",
    "icon.foreground": "#939597",
    "descriptionForeground": "#939597"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "comment.block.documentation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#939597",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#696b6d",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword operators",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.instanceof",
        "keyword.operator.typeof",
        "keyword.operator.logical",
        "keyword.operator.delete"
      ],
      "settings": {
        "foreground": "#696b6d",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage type (class, function, var, let, const)",
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#696b6d",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.template",
        "string.quoted.other"
      ],
      "settings": {
        "foreground": "#9b662f",
        "fontStyle": ""
      }
    },
    {
      "name": "String interpolation",
      "scope": [
        "string.interpolated",
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#696b6d",
        "fontStyle": ""
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#9b662f",
        "fontStyle": ""
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex"
      ],
      "settings": {
        "foreground": "#38793a",
        "fontStyle": ""
      }
    },
    {
      "name": "Language constants (true, false, null)",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#007d62",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Other constants (ALL_CAPS, enums)",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#007d62",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Escape characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#6c6d6f",
        "fontStyle": ""
      }
    },
    {
      "name": "Type names and interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.alias",
        "entity.name.type.module",
        "support.type",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#4f6f79",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Type parameters (generics <T>)",
      "scope": [
        "entity.name.type.parameter"
      ],
      "settings": {
        "foreground": "#4f6f79",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function declarations",
      "scope": [
        "entity.name.function",
        "meta.function entity.name.function"
      ],
      "settings": {
        "foreground": "#786d74",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Function calls",
      "scope": [
        "meta.function-call entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#786d74",
        "fontStyle": ""
      }
    },
    {
      "name": "Method calls",
      "scope": [
        "meta.method-call entity.name.function",
        "entity.name.function.member"
      ],
      "settings": {
        "foreground": "#786d74",
        "fontStyle": ""
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#161617",
        "fontStyle": ""
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#161617",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Language variables (this, self, super)",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#696b6d",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#161617",
        "fontStyle": ""
      }
    },
    {
      "name": "Class names",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#9e4fa5",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Inherited classes",
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#9e4fa5",
        "fontStyle": "italic"
      }
    },
    {
      "name": "HTML/XML tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#696b6d",
        "fontStyle": "bold"
      }
    },
    {
      "name": "HTML/XML attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#786d74",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#6c6d6f",
        "fontStyle": ""
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#939597",
        "fontStyle": ""
      }
    },
    {
      "name": "Decorators / Annotations",
      "scope": [
        "meta.decorator",
        "meta.decorator entity.name.function",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#4f6f79",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.vendored.property-name.css"
      ],
      "settings": {
        "foreground": "#4f6f79",
        "fontStyle": ""
      }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#9e4fa5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "CSS values",
      "scope": [
        "support.constant.property-value.css",
        "support.constant.color.css"
      ],
      "settings": {
        "foreground": "#007d62",
        "fontStyle": ""
      }
    },
    {
      "name": "CSS units",
      "scope": [
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#38793a",
        "fontStyle": ""
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#4f6f79",
        "fontStyle": ""
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "markup.heading entity.name",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#696b6d",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#007d62",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#4f6f79",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown inline code",
      "scope": [
        "markup.inline.raw",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#9b662f",
        "fontStyle": ""
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#786d74",
        "fontStyle": ""
      }
    },
    {
      "name": "Markdown quotes",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#939597",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#88b04b"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#dd4132"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#efc050"
      }
    }
  ]
}