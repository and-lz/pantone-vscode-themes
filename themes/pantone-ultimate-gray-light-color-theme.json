{
  "name": "Pantone Ultimate Gray (Light)",
  "type": "light",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable.declaration": {
      "foreground": "#161617"
    },
    "variable.readonly": {
      "foreground": "#007d62",
      "bold": true
    },
    "parameter.declaration": {
      "foreground": "#161617",
      "italic": true
    },
    "function.declaration": {
      "foreground": "#786d74",
      "bold": true
    },
    "function.defaultLibrary": {
      "foreground": "#786d74"
    },
    "type": {
      "foreground": "#4f6f79",
      "italic": true
    },
    "type.defaultLibrary": {
      "foreground": "#4f6f79",
      "italic": true
    },
    "class": {
      "foreground": "#9e4fa5",
      "bold": true,
      "italic": true
    },
    "interface": {
      "foreground": "#4f6f79",
      "italic": true
    },
    "enum": {
      "foreground": "#4f6f79",
      "italic": true
    },
    "enumMember": {
      "foreground": "#007d62",
      "bold": true
    },
    "namespace": {
      "foreground": "#4f6f79"
    },
    "property.readonly": {
      "foreground": "#007d62",
      "bold": true
    }
  },
  "colors": {
    "editor.background": "#f9f9f9",
    "editor.foreground": "#161617",
    "editorCursor.foreground": "#767779",
    "editor.selectionBackground": "#76777933",
    "editor.inactiveSelectionBackground": "#7677791a",
    "editor.lineHighlightBackground": "#76777914",
    "editor.lineHighlightBorder": "#76777900",
