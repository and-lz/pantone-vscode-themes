    "editor.findMatchHighlightBackground": "#ffbe9833",
    "editor.wordHighlightBackground": "#a3af8633",
    "editorBracketMatch.background": "#a3af8640",
    "editorBracketMatch.border": "#a3af8699",
    "editorIndentGuide.background": "#e0e2df14",
    "editorIndentGuide.activeBackground": "#e0e2df33",
    "editorWhitespace.foreground": "#e0e2df1a",
    "editorRuler.foreground": "#e0e2df14",
