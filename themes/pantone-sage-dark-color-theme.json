{
  "name": "Pantone Sage (Dark)",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable.declaration": {
      "foreground": "#e0e2df"
    },
    "variable.readonly": {
      "foreground": "#996fd1",
      "bold": true
    },
    "parameter.declaration": {
      "foreground": "#e0e2df",
      "italic": true
    },
    "function.declaration": {
      "foreground": "#e8ae4e",
      "bold": true
    },
    "function.defaultLibrary": {
      "foreground": "#e8ae4e"
    },
    "type": {
      "foreground": "#7ba0b4",
      "italic": true
    },
    "type.defaultLibrary": {
      "foreground": "#7ba0b4",
      "italic": true
    },
    "class": {
      "foreground": "#dd487e",
      "bold": true,
      "italic": true
    },
    "interface": {
      "foreground": "#7ba0b4",
      "italic": true
    },
    "enum": {
      "foreground": "#7ba0b4",
      "italic": true
    },
    "enumMember": {
      "foreground": "#996fd1",
      "bold": true
    },
    "namespace": {
      "foreground": "#7ba0b4"
    },
    "property.readonly": {
      "foreground": "#996fd1",
      "bold": true
    }
  },
  "colors": {
    "editor.background": "#141510",
    "editor.foreground": "#e0e2df",
    "editorCursor.foreground": "#a3af86",
    "editor.selectionBackground": "#a3af864d",
