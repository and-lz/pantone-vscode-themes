    "statusBar.noFolderBackground": "#1c1e17",
    "statusBarItem.hoverBackground": "#a3af864d",
    "statusBarItem.remoteBackground": "#a3af86",
    "statusBarItem.remoteForeground": "#181a14",
    "input.background": "#1c1e17",
    "input.foreground": "#e0e2df",
    "input.border": "#313528",
    "input.placeholderForeground": "#92978c",
    "inputOption.activeBorder": "#a3af86",
    "inputValidation.errorBorder": "#dd4132",
    "inputValidation.warningBorder": "#efc050",
    "inputValidation.infoBorder": "#f7a08b",
    "dropdown.background": "#1c1e17",
    "dropdown.foreground": "#e0e2df",
    "dropdown.border": "#313528",
    "list.activeSelectionBackground": "#a3af864d",
    "list.activeSelectionForeground": "#e0e2df",
    "list.hoverBackground": "#a3af8626",
    "list.inactiveSelectionBackground": "#a3af8626",
    "list.focusBackground": "#a3af8633",
    "list.highlightForeground": "#a3af86",
    "button.background": "#a3af86",
    "button.foreground": "#181a14",
    "button.hoverBackground": "#acb792",
    "button.secondaryBackground": "#24261d",
    "button.secondaryForeground": "#e0e2df",
    "badge.background": "#a3af86",
    "badge.foreground": "#181a14",
    "scrollbar.shadow": "#10110d45",
    "scrollbarSlider.background": "#e0e2df1f",
    "scrollbarSlider.hoverBackground": "#e0e2df40",
    "scrollbarSlider.activeBackground": "#e0e2df59",
    "minimap.background": "#141510",
    "minimap.findMatchHighlight": "#ffbe9899",
    "minimap.selectionHighlight": "#a3af8666",
    "panel.background": "#1c1e17",
    "panel.border": "#313528",
    "panelTitle.activeBorder": "#a3af86",
    "panelTitle.activeForeground": "#e0e2df",
    "panelTitle.inactiveForeground": "#92978c",
    "terminal.background": "#1c1e17",
    "terminal.foreground": "#e0e2df",
    "terminalCursor.foreground": "#a3af86",
    "terminal.ansiBlack": "#141510",
    "terminal.ansiRed": "#dd4132",
    "terminal.ansiGreen": "#88b04b",
    "terminal.ansiYellow": "#efc050",
    "terminal.ansiBlue": "#597e84",
    "terminal.ansiMagenta": "#b163a3",
    "terminal.ansiCyan": "#45b5aa",
    "terminal.ansiWhite": "#e0e2df",
    "terminal.ansiBrightBlack": "#92978c",
    "terminal.ansiBrightRed": "#e25e51",
    "terminal.ansiBrightGreen": "#9abc66",
    "terminal.ansiBrightYellow": "#f1c96a",
    "terminal.ansiBrightBlue": "#4b79a1",
    "terminal.ansiBrightMagenta": "#bd7ab1",
    "terminal.ansiBrightCyan": "#61c0b7",
    "terminal.ansiBrightWhite": "#f6f6f6",
    "gitDecoration.addedResourceForeground": "#88b04b",
    "gitDecoration.modifiedResourceForeground": "#efc050",
    "gitDecoration.deletedResourceForeground": "#dd4132",
    "gitDecoration.untrackedResourceForeground": "#88b04b",
    "gitDecoration.conflictingResourceForeground": "#ff6f61",
    "gitDecoration.ignoredResourceForeground": "#92978c",
    "breadcrumb.foreground": "#92978c",
    "breadcrumb.focusForeground": "#e0e2df",
    "breadcrumb.activeSelectionForeground": "#e0e2df",
    "notifications.background": "#24261d",
    "notifications.foreground": "#e0e2df",
    "notificationLink.foreground": "#a3af86",
    "peekView.border": "#a3af86",
    "peekViewEditor.background": "#1c1e17",
    "peekViewResult.background": "#24261d",
    "peekViewTitle.background": "#1c1e17",
    "editorWidget.background": "#1c1e17",
    "editorWidget.border": "#313528",
    "editorSuggestWidget.selectedBackground": "#a3af8640",
    "focusBorder": "#a3af8699",
    "selection.background": "#a3af864d",
    "textLink.foreground": "#f7a08b",
    "textLink.activeForeground": "#f8ae9c",
    "progressBar.background": "#a3af86",
    "icon.foreground": "#92978c",
    "descriptionForeground": "#92978c"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "comment.block.documentation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#92978c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#a3af86",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword operators",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.instanceof",
        "keyword.operator.typeof",
        "keyword.operator.logical",
        "keyword.operator.delete"
      ],
      "settings": {
        "foreground": "#a3af86",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage type (class, function, var, let, const)",
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#a3af86",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.template",
        "string.quoted.other"
      ],
      "settings": {
        "foreground": "#f7a08b",
        "fontStyle": ""
      }
    },
    {
      "name": "String interpolation",
      "scope": [
        "string.interpolated",
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#a3af86",
        "fontStyle": ""
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#f7a08b",
        "fontStyle": ""
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex"
      ],
      "settings": {
        "foreground": "#ffbe98",
        "fontStyle": ""
      }
    },
    {
      "name": "Language constants (true, false, null)",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#996fd1",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Other constants (ALL_CAPS, enums)",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#996fd1",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Escape characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#b1bb98",
        "fontStyle": ""
      }
    },
    {
      "name": "Type names and interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.alias",
        "entity.name.type.module",
        "support.type",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#7ba0b4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Type parameters (generics <T>)",
      "scope": [
        "entity.name.type.parameter"
      ],
      "settings": {
        "foreground": "#7ba0b4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function declarations",
      "scope": [
        "entity.name.function",
        "meta.function entity.name.function"
      ],
      "settings": {
        "foreground": "#e8ae4e",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Function calls",
      "scope": [
        "meta.function-call entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#e8ae4e",
        "fontStyle": ""
      }
    },
    {
      "name": "Method calls",
      "scope": [
        "meta.method-call entity.name.function",
        "entity.name.function.member"
      ],
      "settings": {
        "foreground": "#e8ae4e",
        "fontStyle": ""
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#e0e2df",
        "fontStyle": ""
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#e0e2df",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Language variables (this, self, super)",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#a3af86",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#e0e2df",
        "fontStyle": ""
      }
    },
    {
      "name": "Class names",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#dd487e",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Inherited classes",
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#dd487e",
        "fontStyle": "italic"
      }
    },
    {
      "name": "HTML/XML tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#a3af86",
        "fontStyle": "bold"
      }
    },
    {
      "name": "HTML/XML attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#e8ae4e",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#b1bb98",
        "fontStyle": ""
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#92978c",
        "fontStyle": ""
      }
    },
    {
      "name": "Decorators / Annotations",
      "scope": [
        "meta.decorator",
        "meta.decorator entity.name.function",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#7ba0b4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.vendored.property-name.css"
      ],
      "settings": {
        "foreground": "#7ba0b4",
        "fontStyle": ""
      }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#dd487e",
        "fontStyle": "bold"
      }
    },
    {
      "name": "CSS values",
      "scope": [
        "support.constant.property-value.css",
        "support.constant.color.css"
      ],
      "settings": {
        "foreground": "#996fd1",
        "fontStyle": ""
      }
    },
    {
      "name": "CSS units",
      "scope": [
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#ffbe98",
        "fontStyle": ""
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#7ba0b4",
        "fontStyle": ""
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "markup.heading entity.name",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#a3af86",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#996fd1",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#7ba0b4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown inline code",
      "scope": [
        "markup.inline.raw",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#f7a08b",
        "fontStyle": ""
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#e8ae4e",
        "fontStyle": ""
      }
    },
    {
      "name": "Markdown quotes",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#92978c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#88b04b"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#dd4132"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#efc050"
      }
    }
  ]
}